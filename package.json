    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "postgres": "^3.4.8",
    "posthog-js": "^1.360.2",
    "posthog-node": "^5.21.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
