    "db:studio": "npx dotenv-cli -e .env.local -- drizzle-kit studio",
    "db:push": "npx dotenv-cli -e .env.local -- drizzle-kit push",
    "approve:pg": "npx dotenv-cli -e .env.local -- tsx scripts/approve-pg.ts",
    "approve:mitra": "npx dotenv-cli -e .env.local -- tsx scripts/approve-mitra.ts"
  },
  "dependencies": {
